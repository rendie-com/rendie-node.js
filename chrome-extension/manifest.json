{
   "manifest_version": 3,
   "name": "__MSG_EXTENSION_NAME__",
   "version": "2026.5.15",
   "default_locale": "zh_CN",
   "description": "__MSG_EXTENSION_DESCRIPTION__",
   "homepage_url": "https://www.rendie.com/",
   "key": "",
   "action": {
      "default_icon": {
         "16": "icons/icon16.png",
         "32": "icons/icon32.png"
      },
      "default_title": "Rendie插件 (Alt+S)"
   },
   "background": {
      "service_worker": "js/background.js",
      "type": "module"
   },
   "content_scripts": [
      {
         "js": [
            "js/jquery-4.0.0.min.js",
            "js/content-script.js"
         ],
         "matches": [
            "<all_urls>"
         ],
         "run_at": "document_start"
      }
   ],
   "host_permissions": [
      "<all_urls>"
   ],
   "icons": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
   },
   "devtools_page": "devtools/index.html",
   "permissions": [
      "declarativeNetRequest",
      "downloads",
      "notifications",
      "storage",
      "cookies",
      "webNavigation",
      "activeTab",
      "clipboardWrite",
      "tabs",
      "scripting",
      "proxy"
   ],
   "declarative_net_request": {
      "rule_resources": [
         {
            "enabled": true,
            "id": "rules",
            "path": "rules.json"
         }
      ]
   },
  "commands": {
      "_execute_action": {
         "suggested_key": {
            "default": "Alt+S",
            "mac": "Alt+S"
         },
         "description": "激活该扩展程序（开启/关闭代理）"
      },
      "screenshot": {
         "suggested_key": {
            "default": "Alt+A",
            "mac": "Alt+A"
         },
         "description": "触发网页截图"
      }
   }
}